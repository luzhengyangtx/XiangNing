generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("staff") // owner | staff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  operationLogs OperationLog[]
}

model Product {
  id                  String   @id @default(cuid())
  sku                 String   @unique
  title               String   // 商品标题
  onlineSpec          String?  // 线上规格
  beijingId           String?  // 北京编号
  originalPrice       Float    @default(0) // 价格（原价）
  discountPrice       Float    @default(0) // 折扣价格
  costPrice           Float    @default(0) // 进价
  weight              Float?   // 重量(g)
  categoryL1          String   // 一级分类
  categoryL2          String?  // 二级分类
  mainImage           String?  // 商品主图
  shippingSampleImage String?  // 出库样图
  link                String?  // 1688/货源链接
  purchaseSpec        String?  // 购买规格
  jdSku               String?  // 京东礼定SKU
  packagingMaterial   String?  // 包装耗材
  packagingPrice      Float    @default(0) // 耗材价格
  description         String?  // 备注描述
  unit                String   @default("个")
  safetyStock         Int      @default(0) // 安全库存警戒线
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  platformLinks   ProductPlatformLink[]
  syncTaskItems   SyncTaskItem[]
  warehouseStocks WarehouseInventory[]
  purchaseOrderItems PurchaseOrderItem[]
}

model Warehouse {
  id                String   @id @default(cuid())
  name              String
  code              String   @unique
  address           String?
  isUnattendedMode  Boolean  @default(false) // 无人值守库存模式开关
  createdAt         DateTime @default(now())

  inventories    WarehouseInventory[]
  purchaseOrders PurchaseOrder[]
}

model WarehouseInventory {
  id               String   @id @default(cuid())
  warehouseId      String
  productId        String
  stock            Int      @default(0) // 正常库存
  unattendedStock  Int      @default(0) // 无人值守库存
  shelfId          String?  // 货架编号
  damagedStock     Int      @default(0) // 货损库存
  updatedAt        DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  warehouseId  String
  status       String   @default("pending") // pending | arrived | cancelled
  note         String?
  damageDetail String?  // JSON: [{productId, quantity, reason}]
  createdAt    DateTime @default(now())
  arrivedAt    DateTime?
  updatedAt    DateTime @updatedAt

  warehouse Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  items     PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  sku       String
  quantity  Int
  costPrice Float    @default(0)
  link      String?
  createdAt DateTime @default(now())

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Platform {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  status    String   @default("disconnected") // connected, disconnected, expired
  authType  String   @default("oauth")
  authData  String?
  config    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productLinks ProductPlatformLink[]
  syncTasks    SyncTask[]
}

model ProductPlatformLink {
  id               String   @id @default(cuid())
  productId        String
  platformId       String
  platformProductId String?
  platformSku      String?
  syncStatus       String   @default("pending")
  shelvesStatus    String   @default("off") // on | off — 各平台独立上下架
  lastSyncAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([productId, platformId])
}

model SyncTask {
  id         String    @id @default(cuid())
  platformId String
  type       String
  status     String    @default("pending")
  totalCount Int       @default(0)
  failCount  Int       @default(0)
  errorMsg   String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  platform Platform        @relation(fields: [platformId], references: [id], onDelete: Cascade)
  items    SyncTaskItem[]
}

model SyncTaskItem {
  id           String   @id @default(cuid())
  taskId       String
  productId    String
  status       String   @default("pending")
  errorCode    String?
  errorMessage String?
  createdAt    DateTime @default(now())

  task    SyncTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model OperationLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  detail     String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
